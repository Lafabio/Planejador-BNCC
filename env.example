# ============================================================
# PLANEJADOR BNCC — VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA envie o .env para o Git — adicione-o ao .gitignore!
# ============================================================

# Access Token de PRODUÇÃO do Mercado Pago
# Obtenha em: mercadopago.com.br/developers → Seu aplicativo → Credenciais
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000

# URL onde o index.html está hospedado (sem barra no final)
# Exemplos:
#   https://meuplanejador.com.br
#   https://lafaiete.github.io/planejador-bncc
FRONTEND_URL=https://seu-site.com

# Chave secreta para validar webhooks do Mercado Pago
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=cole_aqui_a_chave_gerada

# Porta do servidor (Railway/Render/Fly usam PORT automaticamente)
PORT=3000
